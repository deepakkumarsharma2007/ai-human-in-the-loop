    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI: dks-api (uvicorn)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "cwd": "${workspaceFolder}/api",
            "console": "integratedTerminal",
            // "args": [
            //     "src.app:app", "--host", "0.0.0.0", "--port", "8001"
            // ],
            "args": "main:app --host localhost --port 8002 --reload",
            "jinja": true,
            "justMyCode": false,
            "envFile": "${workspaceFolder}/api/.env"
            }
    ]
}


